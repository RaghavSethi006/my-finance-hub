{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FinOS",
  "version": "0.1.0",
  "identifier": "com.finos.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "title": "FinOS",
        "label": "main",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
